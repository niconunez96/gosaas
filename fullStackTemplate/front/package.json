{
  "name": "fullstack-template-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
